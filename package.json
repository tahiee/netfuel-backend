{
  "name": "netfuel-backend",
  "version": "1.0.0",
  "main": "index.js",
  "author": "netfuel-backend",
  "repository": "",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "ts-node-dev --transpile-only --no-notify --respawn --ignore-watch node_modules -r tsconfig-paths/register src/server.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/src/server.js",
    "dbgenerate": "drizzle-kit generate",
    "dbpush": "drizzle-kit push",
    "dbmigrate": "ts-node -r tsconfig-paths/register src/scripts/migrate.ts",
    "dbbaseline": "ts-node -r tsconfig-paths/register src/scripts/baseline.ts",
    "dbstudio": "drizzle-kit studio --port 4983",
    "dbdrop": "drizzle-kit drop",
    "dbintrospect": "drizzle-kit introspect",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed-superadmin.ts",
    "tailwind": "npx @tailwindcss/cli -i ./public/input.css -o ./public/output.css --watch",
    "better-auth-generate": "npx @better-auth/cli@latest generate"
  },
  "license": "ISC",
  "_moduleAliases": {
    "@": "dist/src"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "axios": "^1.15.0",
    "better-auth": "^1.6.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.2.2",
    "tsc-alias": "^1.8.16",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
